  "setup_types": [
    {
      "code": "A",
      "name": "Thu-Fri-Mon Magnet",
      "pattern": "Thursday close → Friday range → Monday target"
    },
    {
      "code": "B",
      "name": "Mon-Wed-Thu Magnet",
      "pattern": "Monday open → Wednesday range → Thursday target"
    },
    {
      "code": "C",
      "name": "Gap Fill",
      "pattern": "Overnight gap → fill probability → same-day target"
    },
    {
      "code": "D",
      "name": "Inside Day",
      "pattern": "Narrow-range day → breakout → next-day target"
    },
    {
      "code": "E",
      "name": "PDH/PDL Sweep",
      "pattern": "Previous day H/L sweep → reversal target"
    },
    {
      "code": "F",
      "name": "Weak Extreme",
      "pattern": "Weak high/low → mean reversion target"
    }
  ],
